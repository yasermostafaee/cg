{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.base.json", ".npmrc", "pnpm-workspace.yaml", "pnpm-lock.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "out/**", "*.tsbuildinfo", "!typecheck.tsbuildinfo"],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "lint": {
      "dependsOn": ["@cg/eslint-config#build"],
      "outputs": [],
      "inputs": ["src/**", ".eslintrc*", "eslint.config.*", "package.json"]
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "tests/**", "scripts/**", "vitest.config.*", "package.json"]
    },
    "@cg/template-fixtures#build": {
      "dependsOn": ["^build"],
      "outputs": ["../../fixtures/templates/**"],
      "inputs": ["build.mjs", "*.scene.mjs", "package.json"]
    },
    "@cg/soak-runner#test": {
      "dependsOn": ["^build", "build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**",
        "tests/**",
        "vitest.config.*",
        "package.json",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/apps/*/package.json",
        "$TURBO_ROOT$/packages/*/package.json",
        "$TURBO_ROOT$/tools/*/package.json"
      ]
    },
    "test:integration": {
      "dependsOn": ["^build", "@cg/amcp-mock#build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "tests/integration/**"]
    },
    "test:e2e": {
      "dependsOn": ["build", "@cg/amcp-mock#build"],
      "outputs": ["playwright-report/**", "test-results/**"],
      "inputs": ["src/**", "tests/e2e/**", "playwright.config.*"]
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["release/**"],
      "inputs": ["dist/**", "electron-builder.yml", "resources/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
