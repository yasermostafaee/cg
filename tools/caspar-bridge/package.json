{
  "name": "@cg/caspar-bridge",
  "version": "0.0.0",
  "private": true,
  "description": "Local CasparCG bridge (C-001): a localhost WebSocket server speaking the @cg/shared-ipc contract, backed by the real @cg/caspar-client stack (ServerSession + CommandQueue + OSC pipeline + Reconciler + LayerManager) in its native Node tier.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "caspar-bridge": "./bin/caspar-bridge.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf --glob dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit -p tsconfig.json --tsBuildInfoFile typecheck.tsbuildinfo",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --coverage",
    "start": "node ./bin/caspar-bridge.mjs"
  },
  "dependencies": {
    "@cg/caspar-client": "workspace:*",
    "@cg/shared-ipc": "workspace:*",
    "@cg/shared-schema": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cg/amcp-mock": "workspace:*",
    "@cg/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
