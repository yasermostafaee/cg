{
  "name": "@cg/soak-runner",
  "version": "0.0.0",
  "private": true,
  "description": "Long-running scenario harness for the runtime stack. Drives load/take/update/out cycles against an in-process amcp-mock, samples memory + queue depth, enforces a leak budget.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "cg-soak": "./bin/cg-soak.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf --glob dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit -p tsconfig.json --tsBuildInfoFile typecheck.tsbuildinfo",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@cg/amcp-mock": "workspace:*",
    "@cg/caspar-client": "workspace:*",
    "@cg/shared-schema": "workspace:*"
  },
  "devDependencies": {
    "@cg/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
