{
  "name": "@cg/caspar-client",
  "version": "0.0.0",
  "private": true,
  "description": "CasparCG 2.3.x client: AMCP+OSC transports, command queue, server-session FSM, redundancy adapter, reconciler. Main-tier only.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@cg/shared-schema": "workspace:*"
  },
  "devDependencies": {
    "@cg/amcp-mock": "workspace:*",
    "@cg/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
