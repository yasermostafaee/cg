{
  "name": "@cg/text-shaping",
  "version": "0.0.0",
  "private": true,
  "description": "Pure RTL/bidi utilities: direction detection, ZWNJ, digit conversion, Jalali dates, truncation. Runs in Node, browsers, and broadcast templates.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --coverage"
  },
  "dependencies": {},
  "devDependencies": {
    "@cg/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
