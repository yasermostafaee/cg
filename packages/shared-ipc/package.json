{
  "name": "@cg/shared-ipc",
  "version": "0.0.0",
  "private": true,
  "description": "Typed Electron IPC contracts. Channel registry + Zod-validated invoke/handle helpers. Consumed by both apps' main, preload, and renderer tiers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@cg/shared-schema": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cg/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
