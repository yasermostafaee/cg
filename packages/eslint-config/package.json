{
  "name": "@cg/eslint-config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared ESLint config and tier-boundary rules for the cg monorepo.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf --glob dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit -p tsconfig.json --tsBuildInfoFile typecheck.tsbuildinfo",
    "lint": "eslint . --max-warnings 0",
    "test": "node ./scripts/smoke.mjs"
  },
  "dependencies": {
    "@eslint/js": "^9.17.0",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.20.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
