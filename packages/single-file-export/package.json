{
  "name": "@cg/single-file-export",
  "version": "0.0.0",
  "private": true,
  "description": "Scene → self-contained, file://-safe single-file HTML export (D-019). Inlines the @cg/template-runtime IIFE bundle, base64 fonts + images, and the scene literal. Browser-tier; consumed by the Designer (export) and the Runtime (B-038 template delivery).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "node ./scripts/bundle-runtime.mjs",
    "prebuild": "node ./scripts/bundle-runtime.mjs",
    "build": "tsc -b",
    "pretypecheck": "node ./scripts/bundle-runtime.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json --tsBuildInfoFile typecheck.tsbuildinfo",
    "pretest": "node ./scripts/bundle-runtime.mjs",
    "test": "vitest run --coverage",
    "clean": "rimraf --glob dist src/generated *.tsbuildinfo",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@cg/shared-ipc": "workspace:*",
    "@cg/shared-schema": "workspace:*",
    "@cg/vcg-format": "workspace:*"
  },
  "devDependencies": {
    "@cg/eslint-config": "workspace:*",
    "@cg/template-runtime": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.24.0",
    "eslint": "^9.17.0",
    "happy-dom": "^15.11.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
