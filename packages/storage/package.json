{
  "name": "@cg/storage",
  "version": "0.0.0",
  "private": true,
  "description": "Browser file-based storage abstraction: File System Access, OPFS, and in-memory backends behind one Workspace interface.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit -p tsconfig.json --tsBuildInfoFile typecheck.tsbuildinfo",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@cg/eslint-config": "workspace:*",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
