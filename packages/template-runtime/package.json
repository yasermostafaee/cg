{
  "name": "@cg/template-runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Broadcast-tier JS that ships inside .vcg/index.html. Builds the scene DOM, binds dynamic fields, exposes window.cg + CasparCG global adapters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit -p tsconfig.json --tsBuildInfoFile typecheck.tsbuildinfo",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@cg/shared-schema": "workspace:*",
    "@cg/text-shaping": "workspace:*"
  },
  "devDependencies": {
    "@cg/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "happy-dom": "^15.11.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
