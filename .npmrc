# Workspace-level pnpm settings. Per-user settings (store-dir, etc.) go in ~/.npmrc.

# Workspace behavior
prefer-workspace-packages=true
link-workspace-packages=true
save-workspace-protocol=rolling

# Peer dependencies — tolerant during scaffold; tighten later
auto-install-peers=true
strict-peer-dependencies=false

# Avoid hoisting all dependencies to root; keep strict resolution
shamefully-hoist=false

# Native binary builds (better-sqlite3 etc.) — show progress
node-options=--no-warnings

# Engines
engine-strict=true
