{
  "name": "@cg/designer",
  "version": "0.0.0",
  "private": true,
  "description": "Visual editor for broadcast HTML graphics (.vcg) — browser SPA.",
  "type": "module",
  "scripts": {
    "bundle:runtime": "node ./scripts/bundle-runtime.mjs",
    "predev": "node ./scripts/bundle-runtime.mjs",
    "dev": "vite",
    "prebuild": "node ./scripts/bundle-runtime.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "pretest": "node ./scripts/bundle-runtime.mjs",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "clean": "rimraf dist .vite coverage src/generated *.tsbuildinfo"
  },
  "dependencies": {
    "@cg/lottie-bridge": "workspace:*",
    "@cg/shared-ipc": "workspace:*",
    "@cg/shared-schema": "workspace:*",
    "@cg/starter-templates": "workspace:*",
    "@cg/storage": "workspace:*",
    "@cg/template-runtime": "workspace:*",
    "@cg/text-shaping": "workspace:*",
    "@cg/ui": "workspace:*",
    "@cg/vcg-format": "workspace:*",
    "@vanilla-extract/css": "^1.20.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cg/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.24.0",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
