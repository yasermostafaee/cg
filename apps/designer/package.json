{
  "name": "@cg/designer",
  "version": "0.0.0",
  "private": true,
  "description": "Visual editor for broadcast HTML graphics (.vcg).",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node ./scripts/bundle-runtime.mjs && electron-vite dev",
    "build": "node ./scripts/bundle-runtime.mjs && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "node ./scripts/bundle-runtime.mjs && vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "clean": "rimraf out dist .vite coverage resources/template-runtime *.tsbuildinfo",
    "package": "node ./scripts/bundle-runtime.mjs && electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@cg/shared-ipc": "workspace:*",
    "@cg/shared-schema": "workspace:*",
    "@cg/template-runtime": "workspace:*",
    "@cg/vcg-format": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cg/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.24.0",
    "electron": "^32.2.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
