{
  "name": "@cg/runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Playout controller for CasparCG (AMCP + OSC) with primary/backup redundancy.",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "clean": "rimraf out dist .vite coverage *.tsbuildinfo",
    "package": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@cg/audit": "workspace:*",
    "@cg/caspar-client": "workspace:*",
    "@cg/shared-ipc": "workspace:*",
    "@cg/shared-schema": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cg/amcp-mock": "workspace:*",
    "@cg/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "electron": "^32.2.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
